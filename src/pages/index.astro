---
import BaseLayout from "../layouts/BaseLayout.astro";
import LatestRelease from "../components/LatestRelease.astro";
import LatestNote from "../components/LatestNote.astro";
import { songs } from "../data/songs";

const getOrdinal = (number: number) => {
  const lastTwoDigits = number % 100;

  if (lastTwoDigits >= 11 && lastTwoDigits <= 13) {
    return `${number}th`;
  }

  switch (number % 10) {
    case 1:
      return `${number}st`;
    case 2:
      return `${number}nd`;
    case 3:
      return `${number}rd`;
    default:
      return `${number}th`;
  }
};

const heroSongs = songs.map((song) => ({
  id: song.id,
  title: song.title,
  image: song.image,
  albumLabel: `${getOrdinal(song.albumNumber)} Album『${song.albumTitle}』`,
}));

const fallbackSong = heroSongs[0];
---

<BaseLayout>
  <main>
    <section class="hero">
      <a
        class="hero-cover-link"
        href={`/songs/${fallbackSong.id}`}
        data-random-link
        aria-label={`${fallbackSong.title}の曲ページを見る`}
      >
        <img
          src={fallbackSong.image}
          alt={`${fallbackSong.title} ジャケット`}
          class="hero-cover"
          data-random-cover
        />
      </a>

      <p class="hero-label">
        RANDOM PICK
      </p>

      <h1 data-random-title>
        {fallbackSong.title}
      </h1>

      <p class="hero-album" data-random-album>
        {fallbackSong.albumLabel}
      </p>

      <a
        href={`/songs/${fallbackSong.id}`}
        class="hero-button"
        data-random-link
      >
        曲を見る
      </a>
    </section>

    <LatestRelease />
    <LatestNote />
  </main>
</BaseLayout>

<script define:vars={{ heroSongs }}>
  const randomSong =
    heroSongs[Math.floor(Math.random() * heroSongs.length)];

  const cover = document.querySelector("[data-random-cover]");
  const title = document.querySelector("[data-random-title]");
  const album = document.querySelector("[data-random-album]");
  const links = document.querySelectorAll("[data-random-link]");

  if (cover instanceof HTMLImageElement) {
    cover.src = randomSong.image;
    cover.alt = `${randomSong.title} ジャケット`;
  }

  if (title) {
    title.textContent = randomSong.title;
  }

  if (album) {
    album.textContent = randomSong.albumLabel;
  }

  links.forEach((link) => {
    if (link instanceof HTMLAnchorElement) {
      link.href = `/songs/${randomSong.id}`;

      if (link.classList.contains("hero-cover-link")) {
        link.setAttribute(
          "aria-label",
          `${randomSong.title}の曲ページを見る`
        );
      }
    }
  });
</script>

<style>
  main {
    width: 100%;
  }

  .hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: calc(100% - 36px);
    max-width: 760px;
    margin: 0 auto;
    padding: 120px 0;
    text-align: center;
  }

  .hero-cover-link {
    display: block;
    margin-bottom: 36px;
    border-radius: 22px;
  }

  .hero-cover {
    width: min(78vw, 420px);
    aspect-ratio: 1;
    display: block;
    object-fit: cover;
    border-radius: 22px;
    box-shadow: 0 28px 70px rgba(0, 0, 0, 0.45);
  }

  .hero-label {
    margin: 0;
    color: #fef263;
    font-size: 1rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 100%;
    margin: 0;
    font-size: clamp(3.4rem, 18vw, 6rem);
    line-height: 0.98;
    letter-spacing: -0.055em;
    overflow-wrap: anywhere;
  }

  .hero-album {
    margin: 18px 0 34px;
    color: #b6b6bc;
    font-size: 1.1rem;
  }

  .hero-button {
    min-width: 180px;
    height: 52px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    color: #ffffff;
    text-decoration: none;
    transition:
      background 0.25s,
      color 0.25s;
  }

  .hero-button:hover {
    background: #ffffff;
    color: #111111;
  }

  @media (min-width: 700px) {
    .hero {
      min-height: 84vh;
      width: min(88vw, 1000px);
      padding: 160px 0 100px;
    }

    h1 {
      font-size: clamp(2.2rem, 8vw, 3.8rem);
    }
  }
</style>