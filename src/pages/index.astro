---
import BaseLayout from "../layouts/BaseLayout.astro";
import LatestRelease from "../components/LatestRelease.astro";
import LatestNote from "../components/LatestNote.astro";
---

<BaseLayout>

  <main>

    <section class="hero">

      <p class="sub">
        Official Website
      </p>

      <h1>
        清水慎樹
      </h1>

      <p class="catch">
        音楽と言葉、その先にある物語。
      </p>

    </section>

    <LatestRelease />
<LatestNote />
  </main>

</BaseLayout>

<style>
  main {
    width: 100%;
  }

  .hero {
    min-height: 78svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    width: calc(100% - 36px);
    max-width: 760px;
    margin: 0 auto;
    padding: 132px 0 76px;
  }

  .sub {
    margin: 0 0 14px;
    color: #85858c;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    line-height: 1.5;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    max-width: 100%;
    font-size: clamp(3.4rem, 18vw, 6rem);
    line-height: 0.98;
    letter-spacing: -0.055em;
    overflow-wrap: anywhere;
  }

  .catch {
    max-width: 18em;
    margin: 28px 0 0;
    color: #c7c7cc;
    font-size: clamp(1rem, 5vw, 1.25rem);
    line-height: 1.9;
  }

  @media (min-width: 700px) {
    .hero {
      min-height: 84vh;
      width: min(88vw, 1000px);
      padding: 160px 0 100px;
    }

    .sub {
      margin-bottom: 18px;
    }

    h1 {
      font-size: clamp(5rem, 12vw, 9rem);
    }

    .catch {
      max-width: none;
      margin-top: 34px;
      font-size: 1.4rem;
    }
  }
</style>