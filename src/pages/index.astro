---
import BaseLayout from "../layouts/BaseLayout.astro";
import LatestRelease from "../components/LatestRelease.astro";
import LatestNote from "../components/LatestNote.astro";
---

<BaseLayout>

  <main>

    <section class="hero">

  <img
    src="/images/music/10-rocking-roads/10-4.png"
    alt="Resonates"
    class="hero-cover"
  />

  <p class="hero-label">
    Latest Release
  </p>

  <h1>
    Resonates
  </h1>

  <p class="hero-album">
    10th Album『Rocking Roads』
  </p>

  <a href="/music/rocking-roads" class="hero-button">
    Albumを見る
  </a>

</section>

    <LatestRelease />
<LatestNote />
  </main>

</BaseLayout>

<style>
  main {
    width: 100%;
  }

 .hero {

  min-height: 100svh;

  display: flex;

  flex-direction: column;

  justify-content: center;

  align-items: center;

  text-align: center;

  width: calc(100% - 36px);

  max-width: 760px;

  margin: 0 auto;

  padding: 120px 0;

}

  .sub {
    margin: 0 0 14px;
    color: #85858c;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    line-height: 1.5;
    text-transform: uppercase;
  }
.hero-cover{
  width: min(78vw, 420px);
  aspect-ratio: 1;
  border-radius: 22px;
  margin-bottom: 36px;
  box-shadow: 0 28px 70px rgba(0,0,0,.45);
}

.hero-label{
  margin:0;
  color:#8f8f95;
  font-size:.75rem;
  letter-spacing:.22em;
  text-transform:uppercase;
}

.hero-album{
  margin:18px 0 34px;
  color:#b6b6bc;
  font-size:1.1rem;
}

.hero-button{
  display:inline-flex;
  align-items:center;
  justify-content:center;

  min-width:180px;
  height:52px;

  border:1px solid rgba(255,255,255,.18);
  border-radius:999px;

  color:#fff;
  text-decoration:none;

  transition:.25s;
}

.hero-button:hover{
  background:#fff;
  color:#111;
}
  h1 {
    margin: 0;
    max-width: 100%;
    font-size: clamp(3.4rem, 18vw, 6rem);
    line-height: 0.98;
    letter-spacing: -0.055em;
    overflow-wrap: anywhere;
  }

  .catch {
    max-width: 18em;
    margin: 28px 0 0;
    color: #c7c7cc;
    font-size: clamp(1rem, 5vw, 1.25rem);
    line-height: 1.9;
  }

  @media (min-width: 700px) {
    .hero {
      min-height: 84vh;
      width: min(88vw, 1000px);
      padding: 160px 0 100px;
    }

    .sub {
      margin-bottom: 18px;
    }

    h1 {
      font-size: clamp(5rem, 12vw, 9rem);
    }

    .catch {
      max-width: none;
      margin-top: 34px;
      font-size: 1.4rem;
    }
  }
</style>