---
import Breadcrumb from "../components/Breadcrumb.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

---

<BaseLayout

  title="PROFILE | 清水慎樹 Official Website"

  description="作詞・作曲・音楽制作を行う清水慎樹のプロフィールです。"

><Breadcrumb
  items={[
    { label: "Home", href: "/" },
    { label: "Profile" },
  ]}
/>

  <main>

    <section class="profile-header">

      <p class="label">PROFILE</p>

      <h1>清水慎樹</h1>

      <p class="english-name">Shinju Shimizu</p>

    </section>

    <section class="profile-content">

      <div class="heading">

        <p class="number">01</p>

        <h2>About</h2>

      </div>

      <div class="text">

        <p>

          趣味も30年続けば、<br>
それはもう人生になるものだと思っています。<br>
<br>
現在は「ARMS」という名義で、<br>
リアルを生きる人間の感情や、<br>
人との繋がりを<br>
詩とメロディーで物語にしています。<br>
<br>
この公式サイトは、<br>
作品をまとめた総合案内所として。<br>
<br>
制作のきっかけや作品の解釈、<br>
漫画や物語、そして日々の雑談や交流は<br>
noteでお楽しみいただけましたら幸いです。<br>
        </p>

      </div>

    </section>

    <section class="profile-content">

      <div class="heading">

        <p class="number">02</p>

        <h2>Creative Works</h2>

      </div>

      <div class="works">

        <article>

          <h3>Music</h3>

          <p>作詞、作曲、編曲、音楽制作、楽曲配信</p>

        </article>

        <article>

          <h3>Words</h3>

          <p>歌詞、エッセイ、制作記録、作品解説</p>

        </article>

        <article>

          <h3>Stories</h3>

          <p>漫画、小説、キャラクターと物語の制作</p>

        </article>

      </div>

    </section>

    <section class="links">

      <a class="primary-button" href="/music">

        音楽作品を見る

      </a>

      <a

        class="secondary-button"

        href="https://note.com/shinju_s"

        target="_blank"

        rel="noopener noreferrer"

      >

        noteを読む

      </a>

    </section>

  </main>

</BaseLayout>

<style>

  main {

    width: min(1040px, 88vw);

    margin: 0 auto;

    padding: 180px 0 120px;

  }

  .profile-header {

    padding-bottom: 100px;

  }

  .label,

  .number {

    margin: 0;

    color: #85858c;

    font-size: 0.74rem;

    font-weight: 700;

    letter-spacing: 0.24em;

  }

  h1 {

    margin: 14px 0 10px;

    font-size: clamp(4rem, 12vw, 9rem);

    line-height: 0.95;

    letter-spacing: -0.06em;

  }

  .english-name {

    margin: 0;

    color: #a0a0a6;

    font-size: 1rem;

    letter-spacing: 0.14em;

  }

  .profile-content {

    display: grid;

    grid-template-columns: 260px 1fr;

    gap: 60px;

    padding: 80px 0;

    border-top: 1px solid rgba(255, 255, 255, 0.12);

  }

  h2 {

    margin: 14px 0 0;

    font-size: clamp(2rem, 5vw, 4rem);

    letter-spacing: -0.04em;

  }

  .text {

    max-width: 680px;

    color: #c3c3c8;

    font-size: 1.05rem;

    line-height: 2.1;

  }

  .text p {

    margin: 0 0 28px;

  }

  .works {

    display: grid;

    gap: 0;

  }

  .works article {

    padding: 25px 0;

    border-bottom: 1px solid rgba(255, 255, 255, 0.1);

  }

  .works article:first-child {

    padding-top: 0;

  }

  h3 {

    margin: 0 0 8px;

    font-size: 1.4rem;

  }

  .works p {

    margin: 0;

    color: #96969d;

  }

  .links {

    display: flex;

    flex-wrap: wrap;

    gap: 14px;

    padding-top: 70px;

    border-top: 1px solid rgba(255, 255, 255, 0.12);

  }

  .primary-button,

  .secondary-button {

    display: inline-block;

    padding: 13px 23px;

    border-radius: 999px;

    font-size: 0.9rem;

    font-weight: 700;

    text-decoration: none;

  }

  .primary-button {

    background: #ffffff;

    color: #111111;

  }

  .secondary-button {

    border: 1px solid rgba(255, 255, 255, 0.26);

    color: #ffffff;

  }

  @media (max-width: 700px) {

    main {

      width: calc(100% - 36px);

      padding: 155px 0 80px;

    }

    .profile-header {

      padding-bottom: 75px;

    }

    .profile-content {

      grid-template-columns: 1fr;

      gap: 38px;

      padding: 65px 0;

    }

  }

</style>