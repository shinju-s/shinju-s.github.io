---
import BaseLayout from "../layouts/BaseLayout.astro";
import { albums } from "../data/albums";
import Breadcrumb from "../components/Breadcrumb.astro";

const sortedAlbums = [...albums].sort(
  (a, b) => b.releaseOrder - a.releaseOrder
);

const toOrdinal = (number: number) => {
  const lastTwoDigits = number % 100;

  if (lastTwoDigits >= 11 && lastTwoDigits <= 13) {
    return `${number}th`;
  }

  switch (number % 10) {
    case 1:
      return `${number}st`;
    case 2:
      return `${number}nd`;
    case 3:
      return `${number}rd`;
    default:
      return `${number}th`;
  }
};
---

<BaseLayout
  title="MUSIC | 清水慎樹 Official Website"
  description="清水慎樹のアルバムと楽曲を、最新作から順に紹介します。"
>
  <main>
    <Breadcrumb

  items={[

    { label: "Home", href: "/" },

    { label: "Music" }

  ]}

/>
    <section class="page-heading">
      <p class="label">DISCOGRAPHY</p>
      <h1>MUSIC</h1>
      <p class="introduction">
        清水慎樹が制作した音楽作品を、最新アルバムから順に紹介します。
      </p>
    </section>

    <section class="album-section" aria-labelledby="album-heading">
      <h2 id="album-heading">Albums</h2>

      <div class="album-grid">
        {
          sortedAlbums.map((album) => (
            <a
  class="album-card"
  href={`/music/${album.slug}`}
  aria-label={`${album.title} の収録曲を見る`}
>
              <div class="cover">
                <img
                  src={album.cover}
                  alt={`${album.title} アルバムジャケット`}
                  width="800"
                  height="800"
                  loading="lazy"
                />
              </div>

              <div class="album-info">
                <p class="album-number">
                  {toOrdinal(album.releaseOrder)} Album
                </p>

                <h3>{album.title}</h3>

                <p class="detail-link">収録曲を見る →</p>
              </div>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

<header class="site-header">
  <div class="header-inner">
    <a class="logo" href="/" aria-label="清水慎樹 トップページ">
      清水慎樹
    </a>

    <nav class="desktop-nav" aria-label="メインメニュー">
      <a href="/music">Music</a>
      <a href="/lyrics">Lyrics</a>
      <a href="/note">note</a>
      <a href="/profile">Profile</a>
    </nav>

    <details class="mobile-menu">
      <summary aria-label="メニューを開く">
        <span></span>
        <span></span>
        <span></span>
      </summary>

      <nav aria-label="スマートフォンメニュー">
        <a href="/">Home</a>
        <a href="/music">Music</a>
        <a href="/lyrics">Lyrics</a>
        <a href="/note">note</a>
        <a href="/profile">Profile</a>
      </nav>
    </details>
  </div>
</header>

<style>
  main {
    width: calc(100% - 28px);
    max-width: 1120px;
    margin: 0 auto;
    padding-bottom: 80px;
  }

  .page-heading {
    padding: 132px 0 62px;
  }

  .label {
    margin: 0 0 12px;
    color: #86868d;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    line-height: 1.5;
  }

  h1 {
    margin: 0;
    font-size: clamp(3.7rem, 20vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.055em;
  }

  .introduction {
    max-width: 620px;
    margin: 26px 0 0;
    color: #b5b5bb;
    font-size: 0.95rem;
    line-height: 1.9;
  }

  .album-section {
    padding-top: 54px;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  h2 {
    margin: 0 0 30px;
    font-size: clamp(1.9rem, 10vw, 3rem);
    line-height: 1.2;
    letter-spacing: -0.04em;
  }

  .album-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 34px 14px;
  }

  .album-card {
    display: block;
    min-width: 0;
    color: inherit;
    text-decoration: none;
  }

  .album-card:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: 5px;
    border-radius: 12px;
  }

  .cover {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 10px;
    background: #161618;
  }

  .cover img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center;
    transition:
      transform 0.35s ease,
      opacity 0.35s ease;
  }

  .album-card:hover .cover img {
    transform: scale(1.025);
    opacity: 0.9;
  }

  .album-info {
    padding-top: 12px;
  }

  .album-number {
    margin: 0 0 4px;
    color: #818188;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    line-height: 1.5;
    text-transform: uppercase;
  }

  h3 {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.45;
    overflow-wrap: anywhere;
  }

  .detail-link {
    margin: 7px 0 0;
    color: #9999a0;
    font-size: 0.7rem;
    line-height: 1.5;
  }

  @media (min-width: 700px) {
    main {
      width: min(88vw, 1120px);
      padding-bottom: 120px;
    }

    .page-heading {
      padding: 180px 0 90px;
    }

    .introduction {
      margin-top: 32px;
      font-size: 1.05rem;
    }

    .album-section {
      padding-top: 70px;
    }

    h2 {
      margin-bottom: 42px;
    }

    .album-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 56px 28px;
    }

    .cover {
      border-radius: 14px;
    }

    .album-info {
      padding-top: 18px;
    }

    .album-number {
      margin-bottom: 5px;
      font-size: 0.75rem;
      letter-spacing: 0.12em;
    }

    h3 {
      font-size: clamp(1.25rem, 2.4vw, 1.75rem);
      line-height: 1.3;
    }

    .detail-link {
      margin-top: 10px;
      font-size: 0.85rem;
    }
  }
</style>