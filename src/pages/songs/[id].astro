>
  <main>
    <section class="song-hero">
      <p class="song-number">{song.id}</p>

      <h1>{song.title}</h1>

      {
        album && (
          <a class="album-name" href={`/music/${album.slug}`}>
            {album.title}
          </a>
        )
      }

      <div class="main-cover">
