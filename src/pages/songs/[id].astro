      justify-content: space-between;
      flex-direction: row;
      gap: 30px;
      margin-bottom: 40px;
    }

    .track-link {
      grid-template-columns: 58px minmax(0, 1fr) auto;
      gap: 16px;
      padding: 18px 0;
    }
  }
</style>