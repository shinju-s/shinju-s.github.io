---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { getShinjuArticles } from "../../lib/note";
const articles = await getShinjuArticles();
---

<BaseLayout title="Shinju Note | 清水慎樹 Official Website">

  <Breadcrumb
    items={[
      { label: "Home", href: "/" },
      { label: "Shinju Note" },
    ]}
  />

  <section class="notes-page">
    <p class="label">FROM NOTE</p>

    <h1>Shinju Note</h1>

    <p class="description">
      日々の出来事、ホームページ制作、AI活用、
      ライカ丼丸のこと、考え方などをまとめています。
    </p>

    {
  articles.length > 0 ? (
    <ul class="article-list">
      {articles.map((article) => (
        <li class="article-item">
          <a
            href={article.link}
            target="_blank"
            rel="noopener noreferrer"
          >
            <time>{article.date}</time>
            <h2>{article.title}</h2>
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <div class="coming-soon">
      記事はまだありません。
    </div>
  )
}

  </section>

</BaseLayout>

<style>
.notes-page{
  width:min(900px,92%);
  margin:0 auto;
  padding:80px 0;
}

.label{
  color:#86868d;
  font-size:.72rem;
  font-weight:700;
  letter-spacing:.2em;
}

h1{
  margin:.4rem 0 1rem;
  font-size:clamp(2.3rem,5vw,4rem);
}

.description{
  color:#9d9d9d;
  line-height:1.8;
  max-width:650px;
}

.coming-soon{
  margin-top:50px;
  padding:30px;
  border:1px solid rgba(255,255,255,.12);
  border-radius:18px;
}
.article-list{
  list-style:none;
  padding:0;
  margin:50px 0 0;
}

.article-item{
  border-top:1px solid rgba(255,255,255,.12);
}

.article-item:last-child{
  border-bottom:1px solid rgba(255,255,255,.12);
}

.article-item a{
  display:block;
  padding:24px 0;
  color:inherit;
  text-decoration:none;
  transition:.2s;
}

.article-item a:hover{
  opacity:.75;
}

.article-item time{
  display:block;
  color:#888;
  font-size:.85rem;
  margin-bottom:8px;
}

.article-item h2{
  margin:0;
  font-size:1.35rem;
  line-height:1.5;
}
</style>