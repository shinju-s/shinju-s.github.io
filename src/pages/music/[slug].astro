---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { albums } from "../../data/albums";
import { songs } from "../../data/songs";

export function getStaticPaths() {
  return albums.map((album) => ({
    params: {
      slug: album.slug,
    },
    props: {
      album,
    },
  }));
}

type Props = {
  album: (typeof albums)[number];
};

const { album } = Astro.props as Props;

const albumSongs = songs
  .filter((song) => song.albumNumber === album.releaseOrder)
  .sort((a, b) => a.trackNumber - b.trackNumber);

const toOrdinal = (number: number) => {
  const lastTwoDigits = number % 100;

  if (lastTwoDigits >= 11 && lastTwoDigits <= 13) {
    return `${number}th`;
  }

  switch (number % 10) {
    case 1:
      return `${number}st`;
    case 2:
      return `${number}nd`;
    case 3:
      return `${number}rd`;
    default:
      return `${number}th`;
  }
};
---

<BaseLayout
  title={`${album.title} | 清水慎樹 Official Website`}
  description={`清水慎樹の${toOrdinal(album.releaseOrder)}アルバム『${album.title}』の収録曲一覧です。`}
>
  <main>
    <section class="album-header">
      <div class="cover">
        <img
          src={album.cover}
          alt={`${album.title} アルバムジャケット`}
          width="800"
          height="800"
        />
      </div>

      <div class="album-heading">
        <p class="album-number">
          {toOrdinal(album.releaseOrder)} Album
        </p>

        <h1>{album.title}</h1>

        <p class="track-count">
          {albumSongs.length} Tracks
        </p>

        <a class="back-link" href="/music">
          ← アルバム一覧へ
        </a>
      </div>
    </section>

    <section class="tracks" aria-labelledby="track-heading">
      <p class="section-label">TRACK LIST</p>
      <h2 id="track-heading">収録曲</h2>

      <div class="track-grid">
        {
          albumSongs.map((song) => (
            <article class="track-card">
              <div class="song-cover">
                <img
                  src={song.image}
                  alt={`${song.title} ジャケット`}
                  width="600"
                  height="600"
                  loading="lazy"
                />
              </div>

              <div class="song-info">
                <p class="track-number">
                  {song.id}
                </p>

                <h3>{song.title}</h3>
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  main {
    width: min(1120px, 88vw);
    margin: 0 auto;
    padding-bottom: 120px;
  }

  .album-header {
    display: grid;
    grid-template-columns: minmax(250px, 390px) 1fr;
    gap: clamp(40px, 7vw, 90px);
    align-items: center;
    padding: 170px 0 100px;
  }

  .cover {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 18px;
    background: #161618;
    box-shadow: 0 28px 70px rgba(0, 0, 0, 0.45);
  }

  .cover img,
  .song-cover img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .album-number,
  .section-label,
  .track-number {
    margin: 0;
    color: #85858c;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1 {
    margin: 13px 0 18px;
    font-size: clamp(3rem, 8vw, 7rem);
    line-height: 0.98;
    letter-spacing: -0.055em;
  }

  .track-count {
    margin: 0 0 34px;
    color: #aaaab0;
  }

  .back-link {
    display: inline-block;
    color: #d0d0d4;
    font-size: 0.9rem;
    text-decoration: underline;
    text-underline-offset: 6px;
  }

  .tracks {
    padding-top: 80px;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  h2 {
    margin: 12px 0 42px;
    font-size: clamp(2rem, 5vw, 4rem);
    letter-spacing: -0.04em;
  }

  .track-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 42px 22px;
  }

  .song-cover {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 12px;
    background: #161618;
  }

  .song-info {
    padding-top: 14px;
  }

  h3 {
    margin: 7px 0 0;
    font-size: 1.05rem;
    line-height: 1.45;
  }

  @media (max-width: 900px) {
    .track-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .album-header {
      grid-template-columns: 1fr;
      padding: 150px 0 80px;
    }

    .cover {
      max-width: 360px;
      margin: 0 auto;
    }

    .track-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 430px) {
    main {
      width: calc(100% - 36px);
    }

    .track-grid {
      gap: 34px 16px;
    }

    h3 {
      font-size: 0.95rem;
    }
  }
</style>