---
import Breadcrumb from "../components/Breadcrumb.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { songs } from "../data/songs";

const sortedSongs = [...songs].sort(
  (a, b) =>
    b.albumNumber - a.albumNumber ||
    a.trackNumber - b.trackNumber
);
---

<BaseLayout
  title="LYRICS | 清水慎樹 Official Website"
  description="清水慎樹の全楽曲と歌詞を、曲名やアルバム名から検索できます。"
><Breadcrumb
  items={[
    { label: "Home", href: "/" },
    { label: "Lyrics" },
  ]}
/>
  <main>
    <section class="page-heading">
      <p class="label">SONGS & LYRICS</p>
      <h1>LYRICS</h1>

      <p class="introduction">
        曲名、アルバム名、歌詞の言葉から楽曲を探せます。
      </p>

      <div class="search-area">
        <label for="song-search">楽曲を検索</label>

        <input
          id="song-search"
          type="search"
          placeholder="曲名・アルバム名・歌詞を入力"
          autocomplete="off"
        />
      </div>
    </section>

    <section class="songs-section" aria-labelledby="songs-heading">
      <div class="section-heading">
        <h2 id="songs-heading">All Songs</h2>
        <p>{songs.length} Tracks</p>
      </div>

      <div class="song-grid" id="song-grid">
        {
          sortedSongs.map((song) => (
            <a
              class="song-card"
              href={`/songs/${song.id}`}
              data-song-card
              data-search={`${song.title} ${song.albumTitle} ${song.lyrics ?? ""}`.toLowerCase()}
            >
              <div class="cover">
                <img
                  src={song.image}
                  alt={`${song.title} ジャケット`}
                  width="600"
                  height="600"
                  loading="lazy"
                />
              </div>

              <div class="song-info">
                <p class="song-number">{song.id}</p>
                <h3>{song.title}</h3>
                <p class="album-title">{song.albumTitle}</p>
              </div>
            </a>
          ))
        }
      </div>

      <p id="empty-result" class="empty-result" hidden>
        該当する楽曲が見つかりませんでした。
      </p>
    </section>
  </main>
</BaseLayout>

<script>
  const input = document.querySelector("#song-search");
  const cards = [...document.querySelectorAll("[data-song-card]")];
  const emptyResult = document.querySelector("#empty-result");

  input?.addEventListener("input", () => {
    const query = input.value.trim().toLowerCase();
    let visibleCount = 0;

    cards.forEach((card) => {
      const searchText = card.dataset.search ?? "";
      const isMatch = searchText.includes(query);

      card.hidden = !isMatch;

      if (isMatch) {
        visibleCount += 1;
      }
    });

    if (emptyResult) {
      emptyResult.hidden = visibleCount > 0;
    }
  });
</script>

<style>
  main {
    width: calc(100% - 28px);
    max-width: 1120px;
    margin: 0 auto;
    padding-bottom: 80px;
  }

  .page-heading {
    padding: 132px 0 58px;
  }

  .label {
    margin: 0 0 12px;
    color: #86868d;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    line-height: 1.5;
  }

  h1 {
    margin: 0;
    font-size: clamp(3.7rem, 20vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.055em;
  }

  .introduction {
    max-width: 650px;
    margin: 25px 0 0;
    color: #b5b5bb;
    font-size: 0.95rem;
    line-height: 1.9;
  }

  .search-area {
    margin-top: 36px;
  }

  .search-area label {
    display: block;
    margin-bottom: 9px;
    color: #aaaab0;
    font-size: 0.76rem;
  }

  .search-area input {
    width: 100%;
    min-height: 52px;
    padding: 14px 16px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 12px;
    outline: none;
    background: #151517;
    color: #ffffff;
    font-size: 16px;
  }

  .search-area input::placeholder {
    color: #77777e;
  }

  .search-area input:focus {
    border-color: rgba(255, 255, 255, 0.7);
  }

  .songs-section {
    padding-top: 54px;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .section-heading {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 15px;
    margin-bottom: 30px;
  }

  h2 {
    margin: 0;
    font-size: clamp(1.9rem, 10vw, 3rem);
    line-height: 1.2;
    letter-spacing: -0.04em;
  }

  .section-heading p {
    flex-shrink: 0;
    margin: 0;
    color: #85858c;
    font-size: 0.76rem;
  }

  .song-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 34px 14px;
  }

  .song-card {
    display: block;
    min-width: 0;
    color: inherit;
    text-decoration: none;
  }

  .song-card[hidden] {
    display: none;
  }

  .song-card:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: 5px;
    border-radius: 10px;
  }

  .cover {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 10px;
    background: #161618;
  }

  .cover img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition:
      transform 0.35s ease,
      opacity 0.35s ease;
  }

  .song-card:hover .cover img {
    transform: scale(1.025);
    opacity: 0.9;
  }

  .song-info {
    padding-top: 11px;
  }

  .song-number {
    margin: 0;
    color: #77777e;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    line-height: 1.5;
  }

  h3 {
    margin: 5px 0 3px;
    font-size: 0.92rem;
    line-height: 1.45;
    overflow-wrap: anywhere;
  }

  .album-title {
    margin: 0;
    color: #929298;
    font-size: 0.7rem;
    line-height: 1.5;
    overflow-wrap: anywhere;
  }

  .empty-result {
    padding: 70px 0;
    color: #929298;
    text-align: center;
  }

  @media (min-width: 700px) {
    main {
      width: min(88vw, 1120px);
      padding-bottom: 120px;
    }

    .page-heading {
      padding: 180px 0 90px;
    }

    .introduction {
      margin-top: 30px;
      font-size: 1.05rem;
    }

    .search-area {
      max-width: 680px;
      margin-top: 46px;
    }

    .songs-section {
      padding-top: 70px;
    }

    .section-heading {
      margin-bottom: 42px;
    }

    .section-heading p {
      font-size: 1rem;
    }

    .song-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 44px 22px;
    }

    .cover {
      border-radius: 12px;
    }

    .song-info {
      padding-top: 14px;
    }

    .song-number {
      font-size: 0.72rem;
      letter-spacing: 0.14em;
    }

    h3 {
      margin-top: 6px;
      font-size: 1.05rem;
    }

    .album-title {
      font-size: 0.82rem;
    }
  }
</style>