---
import { site } from "../data/site";
import { getArmsArticles, getShinjuArticles } from "../lib/note";

const personalNoteUrl = site.notes.personal;
const armsNoteUrl = site.notes.arms;

const armsArticles = await getArmsArticles(3);
const personalArticles = await getShinjuArticles(3);
---

<section class="latest-note">
<div class="section-heading">
<div>
<p class="section-label">FROM NOTE</p>
<h2>Latest Notes</h2>
</div>
</div>

<div class="note-grid">
<article class="note-card">
<h3>🎵 ARMS Note</h3>
{armsArticles.length>0?(
<ul>{armsArticles.map(article=>(
<li><a href={article.link} target="_blank" rel="noopener noreferrer">{article.title}</a><time>{article.date}</time></li>
))}</ul>
):(<p>記事はまだありません。</p>)}
<a class="more" href="/notes/arms">
  もっと見る →
</a>
</article>

<article class="note-card">
<h3>👤 Shinju Note</h3>
{personalArticles.length>0?(
<ul>{personalArticles.map(article=>(
<li><a href={article.link} target="_blank" rel="noopener noreferrer">{article.title}</a><time>{article.date}</time></li>
))}</ul>
):(<p>記事はまだありません。</p>)}
<a class="more" href="/notes/shinju">

  もっと見る →

</a>
</article>
</div>
</section>

<style>
.latest-note{width:min(1100px,92%);margin:0 auto;padding:96px 0;}
.section-label{color:#86868d;font-size:.72rem;letter-spacing:.2em;font-weight:700;}
h2{margin:.4rem 0 0;font-size:clamp(2rem,5vw,3.2rem);}
.note-grid{display:grid;gap:24px;margin-top:40px;}
.note-card{border:1px solid rgba(255,255,255,.12);border-radius:20px;padding:28px;background:rgba(255,255,255,.03);}
.note-card h3{margin:0 0 20px;}
.note-card ul{list-style:none;padding:0;margin:0;}
.note-card li{padding:14px 0;border-bottom:1px solid rgba(255,255,255,.08);}
.note-card li:last-child{border-bottom:none;}
.note-card a{color:inherit;text-decoration:none;}
.note-card a:hover{text-decoration:underline;}
time{display:block;margin-top:6px;color:#888;font-size:.85rem;}
.more{display:inline-block;margin-top:22px;font-weight:600;}
@media(min-width:900px){.note-grid{grid-template-columns:1fr 1fr;}}
</style>
