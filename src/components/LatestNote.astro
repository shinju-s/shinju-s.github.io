---
import Parser from "rss-parser";

const noteUrl = "https://note.com/shinju_s";
const rssUrl = `${noteUrl}/rss`;

const parser = new Parser();

let articles: {
  title: string;
  link: string;
  date: string;
}[] = [];

try {
  const feed = await parser.parseURL(rssUrl);

  articles = feed.items.slice(0, 3).map((item) => ({
    title: item.title ?? "無題の記事",
    link: item.link ?? noteUrl,
    date: item.pubDate
      ? new Intl.DateTimeFormat("ja-JP", {
          year: "numeric",
          month: "long",
          day: "numeric",
        }).format(new Date(item.pubDate))
      : "",
  }));
} catch (error) {
  console.error("note RSSの取得に失敗しました。", error);
}
---

<section class="latest-note">
  <div class="section-heading">
    <div>
      <p class="section-label">LATEST NOTE</p>
      <h2>noteの最新記事</h2>
    </div>

    <a
      class="note-link"
      href={noteUrl}
      target="_blank"
      rel="noopener noreferrer"
    >
      noteを見る →
    </a>
  </div>

  {
    articles.length > 0 ? (
      <div class="article-list">
        {articles.map((article) => (
          <a
            class="article"
            href={article.link}
            target="_blank"
            rel="noopener noreferrer"
          >
            <time>{article.date}</time>
            <h3>{article.title}</h3>
            <span>記事を読む →</span>
          </a>
        ))}
      </div>
    ) : (
      <div class="rss-error">
        <p>最新記事を取得できませんでした。</p>

        <a
          href={noteUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          noteを開く →
        </a>
      </div>
    )
  }
</section>

<style>
  .latest-note {
    width: calc(100% - 36px);
    max-width: 760px;
    margin: 0 auto;
    padding: 72px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .section-heading {
    display: flex;
    align-items: flex-start;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 36px;
  }

  .section-label {
    margin: 0;
    color: #86868d;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    line-height: 1.5;
  }

  h2 {
    margin: 10px 0 0;
    font-size: clamp(1.9rem, 9vw, 3rem);
    line-height: 1.2;
    letter-spacing: -0.035em;
  }

  .note-link {
    color: #b8b8bd;
    font-size: 0.9rem;
    line-height: 1.6;
    text-decoration: underline;
    text-underline-offset: 6px;
  }

  .article-list {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .article {
    min-height: 130px;
    display: block;
    padding: 24px 0;
    color: inherit;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    text-decoration: none;
  }

  time {
    display: block;
    margin-bottom: 9px;
    color: #77777e;
    font-size: 0.72rem;
    line-height: 1.5;
  }

  h3 {
    margin: 0;
    font-size: 1.08rem;
    line-height: 1.7;
    overflow-wrap: anywhere;
  }

  .article span {
    display: block;
    margin-top: 14px;
    color: #aaaab0;
    font-size: 0.82rem;
  }

  .rss-error {
    padding: 28px 0;
    color: #929298;
    line-height: 1.8;
  }

  .rss-error p {
    margin: 0 0 10px;
  }

  .rss-error a {
    color: #ffffff;
    text-decoration: underline;
    text-underline-offset: 6px;
  }

  @media (min-width: 700px) {
    .latest-note {
      width: min(88vw, 1000px);
      padding: 96px 0;
    }

    .section-heading {
      align-items: flex-end;
      justify-content: space-between;
      flex-direction: row;
      gap: 32px;
      margin-bottom: 44px;
    }

    .article {
      display: grid;
      grid-template-columns: 150px minmax(0, 1fr) auto;
      gap: 24px;
      align-items: center;
      min-height: 104px;
    }

    time {
      margin: 0;
    }

    .article span {
      margin: 0;
      white-space: nowrap;
    }
  }
</style>